# ═══════════════════════════════════════════════════
# AI Partner — Environment Configuration
# Copy this file to .env and fill in your API keys.
# Only ONE LLM provider key is required to start.
# ═══════════════════════════════════════════════════

# ── LLM Providers (at least one required) ──────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# ── Perplexity (search-native LLM) ─────────────────
# Every Perplexity model is grounded in real-time web results with automatic citations.
# Models: sonar-pro (best), sonar, sonar-reasoning-pro
# Get key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ── Local LLM (optional — runs on your machine) ────
# Point to your Ollama or LM Studio instance.
# On Docker Desktop (Mac/Windows), host.docker.internal resolves to your machine.
# On Linux, use the host's LAN IP (e.g. 192.168.1.x).
OLLAMA_HOST=http://host.docker.internal:11434

# ── Ollama Cloud API (optional — enables web search via Ollama Cloud) ────
# Launched September 2025. Provides web_search + web_fetch endpoints.
# When set, the Ollama adapter gains native web search capability.
# Get key at: https://ollama.com (sign in → account settings → API keys)
# Free tier available.
OLLAMA_API_KEY=

# ── Web Search (optional — SearXNG is built-in) ────
# Add Brave or SerpAPI for additional search coverage.
BRAVE_API_KEY=
SERPAPI_API_KEY=

# ── Messaging Bots (optional) ──────────────────────
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Application ────────────────────────────────────
APP_PORT=3000

# Authentication — set AUTH_ENABLED=true to require login
# Generate JWT_SECRET with: openssl rand -hex 32
AUTH_ENABLED=false
JWT_SECRET=change-me-in-production

# Master key for admin API endpoints (leave empty to disable)
AI_PARTNER_MASTER_KEY=

# ── Workspace (optional) ───────────────────────────
# Where goal executor stores output files.
# Leave blank to use the built-in Docker named volume (aipartner-workspace).
# Set to an absolute host path to access files directly: e.g. /home/user/aipartner-workspace
HOST_WORKSPACE=

# ════════════════════════════════════════════════════
# PRODUCTIVITY INTEGRATIONS (all optional)
# Add any key below — the agent will auto-gain those tools.
# ════════════════════════════════════════════════════

# ── GitHub ─────────────────────────────────────────
# Unlocks: github_search_repos, github_list_issues, github_create_issue,
#          github_get_file, github_list_prs, github_add_comment, github_search_code
# Create at: https://github.com/settings/tokens (classic, repo + read:org scopes)
GITHUB_TOKEN=

# ── Notion ─────────────────────────────────────────
# Unlocks: notion_search, notion_get_page, notion_create_page,
#          notion_query_database, notion_append_blocks
# Create at: https://www.notion.so/my-integrations (then share pages with the integration)
NOTION_API_KEY=

# ── Image Generation ───────────────────────────────
# Unlocks: image_generate (saves PNG to /workspace/images/)
# Uses DALL-E 3 if OPENAI_API_KEY is set (already listed above).
# Or set Stability AI key for an alternative:
STABILITY_API_KEY=

# ── Gmail ──────────────────────────────────────────
# Unlocks: gmail_send, gmail_search, gmail_read, gmail_list_inbox
# Step 1: Enable 2FA on your Google account
# Step 2: Create App Password at https://myaccount.google.com/apppasswords
# Step 3 (for read/search): Get OAuth access token from https://developers.google.com/oauthplayground/
#         (scope: https://www.googleapis.com/auth/gmail.readonly)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_ACCESS_TOKEN=

# ── Google Calendar ────────────────────────────────
# Unlocks: calendar_list_events, calendar_create_event,
#          calendar_check_availability, calendar_delete_event
# Get access token from: https://developers.google.com/oauthplayground/
#   (scope: https://www.googleapis.com/auth/calendar)
# For persistent use, also set refresh token + OAuth client credentials:
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_ID=primary

# ── Google Drive ────────────────────────────────────
# Unlocks: drive_search, drive_get_file, drive_list_folder, drive_create_file, drive_get_file_info
# Same OAuth client as Calendar — add scope: https://www.googleapis.com/auth/drive
GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_DRIVE_REFRESH_TOKEN=

# ── Twitter / X ────────────────────────────────────
# READ (search, get tweets):  TWITTER_BEARER_TOKEN only
# WRITE (post, reply):        All four OAuth 1.0a keys below
# Get credentials at: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Trello ─────────────────────────────────────────
# Unlocks: trello_list_boards, trello_list_cards, trello_create_card,
#          trello_move_card, trello_add_comment, trello_get_board_lists
# Get at: https://trello.com/power-ups/admin → "API Key" then generate a Token
TRELLO_API_KEY=
TRELLO_TOKEN=

# ── Spotify ────────────────────────────────────────
# Unlocks: spotify_search, spotify_play, spotify_pause, spotify_skip,
#          spotify_current_track, spotify_add_to_queue, spotify_create_playlist
# Get access token from: https://developer.spotify.com/documentation/web-api/tutorials/refreshing-tokens
# Required scopes: user-read-playback-state user-modify-playback-state
#                  user-read-currently-playing playlist-modify-public playlist-modify-private
SPOTIFY_ACCESS_TOKEN=
SPOTIFY_REFRESH_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Apify ───────────────────────────────────────────
# Unlocks: apify_run_actor, apify_scrape_url, apify_get_results, apify_proxy_url
# Use for scraping CAPTCHA-protected or JS-heavy sites via headless browsers + residential proxies.
# Free tier: $5/month credit. Create token at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=
