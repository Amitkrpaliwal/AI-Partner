{
    "name": "@ai-coworker/server",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "vitest",
        "test:unit": "vitest run src/tests/unit/",
        "test:coverage": "vitest run --coverage src/tests/unit/",
        "dev:docker": "docker compose -f ../docker-compose.yml -f ../docker-compose.dev.yml up",
        "dev:docker:build": "docker compose -f ../docker-compose.yml -f ../docker-compose.dev.yml up --build",
        "prepare": "husky"
    },
    "dependencies": {
        "@ai-coworker/shared": "1.0.0",
        "@anthropic-ai/sdk": "^0.74.0",
        "@google/generative-ai": "^0.24.1",
        "@modelcontextprotocol/sdk": "^0.6.0",
        "@modelcontextprotocol/server-filesystem": "^0.6.0",
        "@slack/bolt": "^4.6.0",
        "@whiskeysockets/baileys": "^7.0.0-rc.9",
        "adm-zip": "^0.5.16",
        "axios": "^1.13.3",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "discord.js": "^14.14.1",
        "dockerode": "^4.0.9",
        "docx": "^8.5.0",
        "dotenv": "^16.3.1",
        "duck-duck-scrape": "^2.2.7",
        "exceljs": "^4.4.0",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "form-data": "^4.0.5",
        "handlebars": "^4.7.8",
        "jsonwebtoken": "^9.0.3",
        "mammoth": "^1.11.0",
        "multer": "^2.0.2",
        "node-cron": "^3.0.3",
        "node-telegram-bot-api": "^0.66.0",
        "ollama": "^0.6.3",
        "openai": "^6.18.0",
        "pdf-parse": "1.1.1",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "playwright": "^1.58.2",
        "pptxgenjs": "^3.12.0",
        "puppeteer": "^24.37.2",
        "socket.io": "^4.7.2",
        "sqlite-vss": "^0.1.2",
        "sqlite3": "^5.1.6",
        "uuid": "^9.0.1",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.16",
        "@types/dockerode": "^4.0.1",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^20.9.0",
        "@types/node-cron": "^3.0.11",
        "@types/node-telegram-bot-api": "^0.64.0",
        "@types/sqlite3": "^3.1.11",
        "@types/uuid": "^9.0.7",
        "@vitest/coverage-v8": "^4.0.18",
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0",
        "tsx": "^4.6.2",
        "typescript": "^5.2.2",
        "vitest": "^0.34.6"
    },
    "lint-staged": {
        "src/**/*.ts": "vitest run --reporter=verbose src/tests/unit/"
    }
}
